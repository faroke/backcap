{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "@backcap/registry#build": {
      "dependsOn": ["@backcap/shared#build"],
      "inputs": [
        "capabilities/**",
        "adapters/**",
        "bridges/**",
        "src/**",
        "build.ts",
        "../../packages/shared/src/**"
      ],
      "outputs": ["dist/**"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}
