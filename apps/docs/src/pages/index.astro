---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage frontmatter={{
  title: 'Backcap — Production-ready backend features for TypeScript',
  description: 'Stop rewriting the same backend features. Copy production-ready, framework-agnostic code into your TypeScript project.',
  template: 'splash',
  pagefind: false,
  tableOfContents: false,
  editUrl: false,
  prev: false,
  next: false,
}}>

<div class="landing not-content" data-base={base}>

  <!-- Hero -->
  <section class="lp-hero">
    <div class="bg-grid"></div>
    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
    <div class="container hero-content">
      <div style="max-width:56rem;margin:0 auto">
        <div class="anim visible">
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            <span>Open source · TypeScript · AI-ready</span>
          </div>
        </div>
        <h1 class="anim visible d1">Stop rewriting the same<br/><span class="text-gradient">backend features.</span></h1>
        <p class="hero-sub anim visible d2">
          Auth, billing, search and more — built right, works everywhere, owned by you.<br/>
          Copy production-ready code your AI agent already understands.
        </p>
        <div class="hero-ctas anim visible d3">
          <a href={`${base}/getting-started/introduction`} class="btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/faroke/backcap" target="_blank" rel="noopener noreferrer" class="btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            GitHub
          </a>
        </div>
        <div class="anim visible d4" style="display:flex;flex-direction:column;align-items:center;margin-bottom:4rem">
          <div class="cmd-box">
            <span class="dollar">$</span>
            <span>npx @backcap/cli init</span>
            <button class="cmd-copy" title="Copy">
              <svg class="cmd-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
              <svg class="cmd-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
          <p class="hero-aside"><em>Think shadcn/ui, but for your backend.</em></p>
        </div>
      </div>
      <div class="anim visible d5">
        <div class="terminal" id="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot red"></div>
            <div class="terminal-dot yellow"></div>
            <div class="terminal-dot green"></div>
            <span class="terminal-title">~/my-app</span>
          </div>
          <div class="terminal-body" id="terminal-body"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="section-with-glow">
    <div class="section-orb left"></div>
    <div class="section-orb right"></div>
    <div class="container">
      <h2 class="section-title anim">You've <span class="text-gradient">already built this</span> before.</h2>
      <p class="section-sub anim">
        Every backend project rebuilds the same features — authentication, permissions, blog, search, notifications, billing. Sound familiar?
      </p>
      <div class="problem-grid">
        <div class="problem-card bad anim from-left">
          <h3>Traditional backend development</h3>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Rewrite auth from scratch — <em>again</em></span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Build custom permissions — <em>for the third time</em></span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Implement <em>yet another</em> blog system</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Create <em>yet another</em> search engine</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Set up notifications — <em>once more</em></span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Handle billing logic — <em>again</em></span></div>
        </div>
        <div class="problem-card good glow-primary glow-enhanced anim from-right">
          <h3>With Backcap</h3>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add auth</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add rbac</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add blog</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add search</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add notifications</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add billing</code></div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-section">
    <div class="bg-grid"></div>
    <div class="container">
      <h2 class="section-title anim">Three steps. <span class="text-gradient">That's it.</span></h2>
      <div class="how-grid">
        <div class="step anim">
          <span class="step-number">01</span>
          <h3>Install the CLI</h3>
          <p>Initialize Backcap in your existing TypeScript project.</p>
          <div class="step-code">npx @backcap/cli init</div>
        </div>
        <div class="step anim d1">
          <span class="step-number">02</span>
          <h3>Add what you need</h3>
          <p>Pick the backend features for your project.</p>
          <div class="step-code">
            <div>npx @backcap/cli add auth</div>
            <div>npx @backcap/cli add blog</div>
            <div>npx @backcap/cli add search</div>
          </div>
        </div>
        <div class="step anim d2">
          <span class="step-number">03</span>
          <h3>It's your code now</h3>
          <p>Full source code, directly in your project. Every feature follows the same clean structure.</p>
          <div class="step-code step-tree">
            <div class="tree-muted">your-project/</div>
            <div>&nbsp;&nbsp;└── <span class="tree-primary">domains/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;└── <span class="tree-primary">auth/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span class="tree-accent">contracts/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span class="tree-accent">domain/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;└── <span class="tree-accent">application/</span></div>
          </div>
        </div>
      </div>
      <div class="how-trio anim">
        <span>Edit anything</span>
        <span class="trio-dot"></span>
        <span>Use AI skills</span>
        <span class="trio-dot"></span>
        <span>No lock-in</span>
      </div>
      <div class="section-cta anim">
        <a href={`${base}/getting-started/introduction`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Read the getting started guide
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features-section" id="features">
    <div class="container">
      <div style="text-align:center;margin-bottom:4rem" class="anim">
        <h2 class="section-title" style="margin-bottom:1rem">Pick what <span class="text-gradient">you need.</span></h2>
        <p style="color:var(--lp-muted);font-size:1.125rem;max-width:32rem;margin:0 auto">
          Production-ready backend features — full source code, zero dependency.
        </p>
      </div>
      <div class="features-grid">
        <div class="features-list">
          <a href={`${base}/domains/auth`} class="feature-row anim">
            <div class="feature-icon" style="background:hsl(152 76% 52% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(152 76% 52%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            </div>
            <div class="feature-info">
              <h3>Auth</h3>
              <p>Sign-up, login, sessions & API keys</p>
            </div>
            <code class="feature-cmd">add auth</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains/billing`} class="feature-row anim d1">
            <div class="feature-icon" style="background:hsl(45 96% 58% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(45 96% 58%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            </div>
            <div class="feature-info">
              <h3>Billing</h3>
              <p>Payments, subscriptions & invoicing</p>
            </div>
            <code class="feature-cmd">add billing</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains/search`} class="feature-row anim d2">
            <div class="feature-icon" style="background:hsl(200 80% 55% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(200 80% 55%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <div class="feature-info">
              <h3>Search</h3>
              <p>Full-text search with filters & facets</p>
            </div>
            <code class="feature-cmd">add search</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains/rbac`} class="feature-row anim d3">
            <div class="feature-icon" style="background:hsl(45 96% 58% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(45 96% 58%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="feature-info">
              <h3>RBAC</h3>
              <p>Roles, permissions & access control</p>
            </div>
            <code class="feature-cmd">add rbac</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains/notifications`} class="feature-row anim d4">
            <div class="feature-icon" style="background:hsl(280 70% 60% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(280 70% 60%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            </div>
            <div class="feature-info">
              <h3>Notifications</h3>
              <p>In-app, email & push notifications</p>
            </div>
            <code class="feature-cmd">add notifications</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains/blog`} class="feature-row anim d5">
            <div class="feature-icon" style="background:hsl(172 66% 50% / 0.1)">
              <svg viewBox="0 0 24 24" fill="none" stroke="hsl(172 66% 50%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            </div>
            <div class="feature-info">
              <h3>Blog</h3>
              <p>Posts, categories, drafts & publishing</p>
            </div>
            <code class="feature-cmd">add blog</code>
            <svg class="feature-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`${base}/domains`} class="features-more anim">+ 14 more features &rarr;</a>
        </div>
        <div class="features-tree anim from-right">
          <div class="features-tree-label">What you get</div>
          <div class="features-tree-code">
            <div><span class="tree-fg">domains/</span></div>
            <div>&nbsp;&nbsp;└── <span class="tree-primary">auth/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span class="tree-accent">contracts/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;├── <span class="tree-muted">auth.port.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;├── <span class="tree-muted">session.port.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;└── <span class="tree-muted">auth.types.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span class="tree-accent">domain/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;├── <span class="tree-muted">auth.service.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;└── <span class="tree-muted">session.entity.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;└── <span class="tree-accent">application/</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span class="tree-muted">sign-up.use-case.ts</span></div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;└── <span class="tree-muted">login.use-case.ts</span></div>
          </div>
          <p class="features-tree-note">Every feature follows the same clean structure.</p>
        </div>
      </div>
      <div class="section-cta anim">
        <a href={`${base}/concepts/domains`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          How features work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- AI-ready -->
  <section class="ai-section">
    <div class="bg-grid"></div>
    <div class="container">
      <h2 class="section-title anim"><span class="text-gradient">AI-ready</span> by design.</h2>
      <p class="section-sub anim">Each feature ships with AI skills. Your agent understands your code from day one.</p>
      <div class="ai-grid">
        <a href={`${base}/concepts/skills`} class="ai-card anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
          <h3>Your AI agent, onboarded</h3>
          <p>Each feature ships with skills — instructions your AI agent reads to extend, test, and debug your code.</p>
        </a>
        <a href={`${base}/concepts/architecture`} class="ai-card anim d1">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <h3>Generate, don't write</h3>
          <p>Ask your agent to add a feature — it follows the same patterns automatically.</p>
        </a>
        <a href={`${base}/concepts/domains`} class="ai-card anim d2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/></svg>
          <h3>Interfaces your AI can read</h3>
          <p>Typed ports and boundaries. Your agent generates compatible code on the first try.</p>
        </a>
      </div>
      <div class="section-cta anim">
        <a href={`${base}/concepts/skills`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          Explore AI skills
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Frameworks -->
  <section class="fw-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem" class="anim">
        <h2 class="section-title" style="margin-bottom:1rem">Works with <span class="text-gradient">your stack.</span></h2>
        <p style="color:var(--lp-muted);font-size:1.125rem;max-width:32rem;margin:0 auto">
          Same code, any TypeScript runtime or framework.
        </p>
      </div>
      <div class="fw-centered">
        <div class="arch-label anim">Runtimes</div>
        <div class="fw-grid runtimes anim">
          <div class="fw-card">
            <div class="fw-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg></div>
            <span class="fw-card-name">Node.js</span>
          </div>
          <div class="fw-card">
            <div class="fw-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
            <span class="fw-card-name">Bun</span>
          </div>
          <div class="fw-card">
            <div class="fw-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg></div>
            <span class="fw-card-name">Deno</span>
