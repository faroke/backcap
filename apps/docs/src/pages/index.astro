---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage frontmatter={{
  title: 'Backcap — The shadcn/ui for backends',
  description: 'A registry of composable backend capabilities for TypeScript. Install backend features like packages.',
  template: 'splash',
  pagefind: false,
  tableOfContents: false,
  editUrl: false,
  prev: false,
  next: false,
}}>

<div class="landing" data-base={base}>

  <!-- Hero -->
  <section class="lp-hero">
    <div class="bg-grid"></div>
    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
    <div class="container hero-content">
      <div style="max-width:56rem;margin:0 auto">
        <div class="anim visible">
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            <span>shadcn/ui for backend capabilities</span>
          </div>
        </div>
        <h1 class="anim visible d1">The <span class="text-gradient">shadcn/ui</span><br/>for backends.</h1>
        <p class="hero-sub anim visible d2">
          Copy and own backend capabilities.<br/>
          Auth, Blog, Search, Payments and more — ready for any TypeScript backend.
        </p>
        <div class="hero-ctas anim visible d3">
          <a href={`${base}/getting-started/introduction`} class="btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#capabilities" class="btn-outline">
            Explore capabilities
          </a>
          <a href="https://github.com/faroke/backcap" target="_blank" rel="noopener noreferrer" class="btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            GitHub
          </a>
        </div>
        <div class="anim visible d4" style="display:flex;justify-content:center;margin-bottom:4rem">
          <div class="cmd-box">
            <span class="dollar">$</span>
            <span>npx @backcap/cli add auth</span>
            <button class="cmd-copy" onclick="navigator.clipboard.writeText('npx @backcap/cli add auth')" title="Copy">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
        </div>
      </div>
      <div class="anim visible d5">
        <div class="terminal" id="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot red"></div>
            <div class="terminal-dot yellow"></div>
            <div class="terminal-dot green"></div>
            <span class="terminal-title">~/my-app</span>
          </div>
          <div class="terminal-body" id="terminal-body"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section>
    <div class="container">
      <h2 class="section-title anim">Stop rewriting <span class="text-gradient">backend features.</span></h2>
      <p class="section-sub anim">
        Every backend project rebuilds the same features — authentication, permissions, blog, search, notifications, billing. This slows development and creates duplicated logic across projects.
      </p>
      <div class="problem-grid">
        <div class="problem-card bad anim from-left">
          <h3>Traditional backend development</h3>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Rewrite auth from scratch</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Build custom permissions</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Implement blog system</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Create search engine</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Set up notifications</span></div>
          <div class="problem-item bad-item"><svg class="icon-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span>Handle billing logic</span></div>
        </div>
        <div class="problem-card good glow-primary anim from-right">
          <h3>Backcap capabilities</h3>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add auth</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add rbac</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add blog</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add search</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add notifications</code></div>
          <div class="problem-item good-item"><svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><code>npx @backcap/cli add billing</code></div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-section">
    <div class="bg-grid"></div>
    <div class="container">
      <h2 class="section-title anim">Install backend <span class="text-gradient">capabilities.</span></h2>
      <div class="how-grid">
        <div class="step anim">
          <span class="step-number">01</span>
          <h3>Install the CLI</h3>
          <p>Initialize Backcap in your existing TypeScript project.</p>
          <div class="step-code">npx @backcap/cli init</div>
        </div>
        <div class="step anim d1">
          <span class="step-number">02</span>
          <h3>Add capabilities</h3>
          <p>Pick the backend features you need.</p>
          <div class="step-code">
            <div>npx @backcap/cli add auth</div>
            <div>npx @backcap/cli add blog</div>
            <div>npx @backcap/cli add search</div>
          </div>
        </div>
        <div class="step anim d2">
          <span class="step-number">03</span>
          <h3>Use them in your backend</h3>
          <p>Capabilities are added directly to your project with full source code. No vendor lock-in.</p>
        </div>
      </div>
      <div class="section-cta anim">
        <a href={`${base}/getting-started/introduction`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Read the getting started guide
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Examples -->
  <section>
    <div class="container">
      <h2 class="section-title anim">Build anything with <span class="text-gradient">capabilities.</span></h2>
      <div class="examples-grid">
        <div class="example-card anim">
          <svg class="example-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          <h3>SaaS</h3>
          <div class="example-list">
            <div><span class="plus">+</span> <span>authentication</span></div>
            <div><span class="plus">+</span> <span>organizations</span></div>
            <div><span class="plus">+</span> <span>billing</span></div>
            <div><span class="plus">+</span> <span>feature-flags</span></div>
            <div><span class="plus">+</span> <span>notifications</span></div>
          </div>
        </div>
        <div class="example-card anim d1">
          <svg class="example-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          <h3>Ecommerce</h3>
          <div class="example-list">
            <div><span class="plus">+</span> <span>catalog</span></div>
            <div><span class="plus">+</span> <span>cart</span></div>
            <div><span class="plus">+</span> <span>orders</span></div>
            <div><span class="plus">+</span> <span>payments</span></div>
            <div><span class="plus">+</span> <span>inventory</span></div>
          </div>
        </div>
        <div class="example-card anim d2">
          <svg class="example-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          <h3>Content Platform</h3>
          <div class="example-list">
            <div><span class="plus">+</span> <span>blog</span></div>
            <div><span class="plus">+</span> <span>comments</span></div>
            <div><span class="plus">+</span> <span>tags</span></div>
            <div><span class="plus">+</span> <span>media</span></div>
            <div><span class="plus">+</span> <span>analytics</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="cap-section" id="capabilities">
    <div class="container">
      <div style="text-align:center;margin-bottom:4rem" class="anim">
        <span class="cap-badge">plug &amp; play</span>
        <h2 class="section-title" style="margin-bottom:1rem">Available <span class="text-gradient">capabilities.</span></h2>
        <p style="color:var(--lp-muted);font-size:1.125rem;max-width:32rem;margin:0 auto">
          Ready-to-install backend features — full source code, zero lock-in.
        </p>
      </div>
      <div class="cap-grid" id="cap-grid"></div>
      <div class="section-cta anim">
        <a href={`${base}/concepts/capabilities`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Learn how capabilities work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section id="architecture">
    <div class="container">
      <div class="arch-grid">
        <div class="arch-text anim from-left">
          <h2>Framework agnostic <span class="text-gradient">by design.</span></h2>
          <p>Backcap uses a modular architecture inspired by clean architecture and hexagonal architecture. The core domain is independent from frameworks.</p>
          <div class="arch-label">Runtimes</div>
          <div class="arch-tags">
            <span class="arch-tag">Node</span>
            <span class="arch-tag">Bun</span>
            <span class="arch-tag">Deno</span>
          </div>
          <div class="arch-label">Frameworks</div>
          <div class="arch-tags">
            <span class="arch-tag">Next.js</span>
            <span class="arch-tag">Express</span>
            <span class="arch-tag">Fastify</span>
            <span class="arch-tag">NestJS</span>
          </div>
        </div>
        <div class="arch-tree anim from-right">
          <div class="muted" style="font-size:0.75rem;margin-bottom:0.5rem">project/</div>
          <div style="margin-left:0.5rem;display:flex;flex-direction:column;gap:0.375rem">
            <div>├── <span class="dir">capabilities/</span></div>
            <div style="margin-left:1.5rem" class="muted">├── auth</div>
            <div style="margin-left:1.5rem" class="muted">├── blog</div>
            <div style="margin-left:1.5rem" class="muted">└── search</div>
            <div>├── <span class="accent-dir">adapters/</span></div>
            <div>├── <span class="accent-dir">bridges/</span></div>
            <div style="margin-left:1.5rem" class="muted">├── auth-audit-log</div>
            <div style="margin-left:1.5rem" class="muted">└── blog-search</div>
            <div>└── <span class="accent-dir">shared/</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Section -->
  <section class="ai-section">
    <div class="bg-grid"></div>
    <div class="container">
      <h2 class="section-title anim">Built for <span class="text-gradient">AI-assisted</span> development.</h2>
      <p class="section-sub anim">Every capability is structured so AI tools can understand and extend your backend.</p>
      <div class="ai-grid">
        <div class="ai-card anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <h3>Clear specifications</h3>
          <p>Each capability includes a spec.yaml contract readable by humans and AI alike.</p>
        </div>
        <div class="ai-card anim d1">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/></svg>
          <h3>Domain contracts</h3>
          <p>Typed interfaces and ports that AI tools can understand and extend automatically.</p>
        </div>
        <div class="ai-card anim d2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
          <h3>AI-friendly structure</h3>
          <p>Consistent architecture lets LLMs generate, modify and compose capabilities.</p>
        </div>
      </div>
      <div class="section-cta anim">
        <a href={`${base}/concepts/skills`} class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          Explore AI skills
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-orb"></div>
    <div class="container cta-content anim">
      <h2>Start building <span class="text-gradient">faster backends.</span></h2>
      <p class="sub">Stop rewriting. Start composing.</p>
      <div class="cta-btns">
        <a href={`${base}/getting-started/introduction`} class="btn-primary">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#capabilities" class="btn-outline">Explore Capabilities</a>
      </div>
      <a href="https://github.com/faroke/backcap" target="_blank" rel="noopener noreferrer" class="cta-github">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        View on GitHub
      </a>
      <div class="cta-footer">
        <span>TypeScript</span>
        <span class="cta-dot"></span>
        <span>Open Source</span>
        <span class="cta-dot"></span>
        <span>AI-Native</span>
      </div>
    </div>
  </section>

</div>

</StarlightPage>

<style is:global>
  /* ── Override Starlight layout for full-bleed landing (scoped to pages with .landing) ── */
  main:has(.landing) { padding: 0 !important; }
  main:has(.landing) > .content-panel:first-child { display: none !important; }
  main:has(.landing) .content-panel { padding: 0 !important; border: none !important; }
  main:has(.landing) .sl-container { max-width: none !important; }
  main:has(.landing) .sl-container > * + * { margin-top: 0 !important; }
  main:has(.landing) .sl-markdown-content > * + * { margin-top: 0 !important; }
  main:has(.landing) footer { display: none !important; }

  /* ── Landing page variables ── */
  .landing {
    --lp-bg: hsl(220 20% 4%);
    --lp-fg: hsl(210 20% 92%);
    --lp-card: hsl(220 18% 7%);
    --lp-primary: hsl(152 76% 52%);
    --lp-primary-fg: hsl(220 20% 4%);
    --lp-accent: hsl(172 66% 50%);
    --lp-secondary: hsl(220 16% 12%);
    --lp-muted: hsl(215 14% 50%);
    --lp-border: hsl(220 14% 16%);
    --lp-destructive: hsl(0 84% 60%);

    font-family: 'Inter', system-ui, sans-serif;
    background: var(--lp-bg);
    color: var(--lp-fg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .landing .font-mono { font-family: 'JetBrains Mono', monospace; }
  .landing a { color: inherit; text-decoration: none; }
  .landing .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── Utilities ── */
  .landing .text-gradient {
    background-image: linear-gradient(135deg, var(--lp-primary), var(--lp-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .landing .glow-primary { box-shadow: 0 0 40px hsl(152 76% 52% / 0.15); }
  .landing .border-glow { border-color: hsl(152 76% 52% / 0.3); }

  .landing .bg-grid {
    background-image:
      linear-gradient(hsl(220 14% 16% / 0.5) 1px, transparent 1px),
      linear-gradient(90deg, hsl(220 14% 16% / 0.5) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ── Animations ── */
  @keyframes lp-fade-in-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes lp-fade-in-left {
    from { opacity: 0; transform: translateX(-24px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes lp-fade-in-right {
    from { opacity: 0; transform: translateX(24px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes lp-terminal-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .landing .anim { opacity: 0; transform: translateY(24px); }
  .landing .anim.visible { animation: lp-fade-in-up 0.6s ease-out forwards; }
  .landing .anim.from-left { transform: translateX(-24px); }
  .landing .anim.from-left.visible { animation: lp-fade-in-left 0.6s ease-out forwards; }
  .landing .anim.from-right { transform: translateX(24px); }
  .landing .anim.from-right.visible { animation: lp-fade-in-right 0.6s ease-out forwards; }

  .landing .d1 { animation-delay: 0.1s; }
  .landing .d2 { animation-delay: 0.2s; }
