  <script>
    // ── Scroll animations ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.anim:not(.visible)').forEach(el => observer.observe(el));

    // ── GitHub star count ──
    fetch('https://api.github.com/repos/faroke/backcap')
      .then(r => r.json())
      .then(d => {
        const el = document.getElementById('star-num');
        if (el && typeof d.stargazers_count === 'number') {
          el.textContent = d.stargazers_count;
        }
      }).catch(() => {});

    // ── Terminal animation ──
    // Realistic clack-style output matching the actual backcap CLI
    const lines = [
      // Command 1: backcap init
      { html: '<span class="prompt-char">$ </span><strong>npx backcap add auth</strong>', cls: 'tl-cmd', delay: 800 },
      { html: '', cls: 'tl-empty', delay: 60 },
      // clack intro
      { html: '┌  <strong>backcap add</strong>', cls: 'tl-clack-intro', delay: 300 },
      { html: '│', cls: 'tl-clack-bar', delay: 80 },
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-info">ℹ</span> Fetching auth...', cls: '', delay: 400 },
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-info">ℹ</span> Detected framework: fastify', cls: '', delay: 200 },
      { html: '│', cls: 'tl-clack-bar', delay: 80 },
      // files written
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-success">✓</span> Capability files written', cls: '', delay: 120 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/domain/user.ts', cls: 'tl-file', delay: 60 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/domain/session.ts', cls: 'tl-file', delay: 60 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/application/ports/auth-provider.port.ts', cls: 'tl-file', delay: 60 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/application/use-cases/sign-in.use-case.ts', cls: 'tl-file', delay: 60 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/application/use-cases/sign-up.use-case.ts', cls: 'tl-file', delay: 60 },
      { html: '  <span class="plus">+</span> src/capabilities/auth/contracts/auth.contract.ts', cls: 'tl-file', delay: 60 },
      { html: '│', cls: 'tl-clack-bar', delay: 80 },
      // adapter
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-info">ℹ</span> Fetching adapter auth-prisma...', cls: '', delay: 300 },
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-success">✓</span> Adapter files written', cls: '', delay: 150 },
      { html: '│', cls: 'tl-clack-bar', delay: 80 },
      // skill
      { html: '<span class="tl-tag">[backcap]</span> <span class="tl-success">✓</span> Skill installed to .claude/skills/backcap-auth/', cls: '', delay: 150 },
      { html: '│', cls: 'tl-clack-bar', delay: 80 },
      // outro
      { html: '└  auth v1.0.0 installed successfully!', cls: 'tl-outro', delay: 0 },
    ];

    const body = document.getElementById('terminal-body');
    let idx = 0;

    function addLine() {
      if (idx >= lines.length) return;
      const line = lines[idx];
      const div = document.createElement('div');
      div.className = 'terminal-line show ' + line.cls;
      div.innerHTML = line.html;
      const cursor = body.querySelector('.terminal-cursor');
      if (cursor) cursor.remove();
      body.appendChild(div);
      idx++;
      if (idx < lines.length) {
        const c = document.createElement('span');
        c.className = 'terminal-cursor';
        body.appendChild(c);
        setTimeout(addLine, lines[idx].delay);
      }
    }

    const terminalObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setTimeout(addLine, 500);
          terminalObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    terminalObs.observe(document.getElementById('terminal'));

    // ── Capabilities grid ──
    const capabilities = [
      { name: 'Authentication', desc: 'User sign-up, login, sessions and API keys.', color: '152 76% 52%', icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>' },
      { name: 'Blog', desc: 'Posts, categories, drafts and publishing.', color: '172 66% 50%', icon: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>' },
      { name: 'Search', desc: 'Full-text search with filters and facets.', color: '200 80% 55%', icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>' },
      { name: 'Files', desc: 'Upload, storage and file management.', color: '38 92% 55%', icon: '<path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/>' },
      { name: 'Notifications', desc: 'In-app, email and push notifications.', color: '280 70% 60%', icon: '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>' },
      { name: 'Webhooks', desc: 'Outbound event delivery and retries.', color: '152 76% 52%', icon: '<path d="M18 16.98h-5.99c-1.1 0-1.95.94-2.48 1.9A4 4 0 0 1 2 17c.01-.7.2-1.4.57-2"/><path d="m6 17 3.13-5.78c.53-.97.1-2.18-.5-3.1a4 4 0 1 1 6.89-4.06"/><path d="m12 6 3.13 5.73C15.66 12.7 16.9 13 18 13a4 4 0 0 1 0 8H12"/>' },
      { name: 'Queues', desc: 'Background jobs and task processing.', color: '172 66% 50%', icon: '<rect width="7" height="18" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/>' },
      { name: 'Feature Flags', desc: 'Toggle features per user or environment.', color: '340 75% 55%', icon: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/>' },
      { name: 'Audit Log', desc: 'Track every action in your system.', color: '200 80% 55%', icon: '<rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>' },
      { name: 'Analytics', desc: 'Events, metrics and dashboards.', color: '38 92% 55%', icon: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
      { name: 'Forms', desc: 'Dynamic form schemas and submissions.', color: '280 70% 60%', icon: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/>' },
      { name: 'Comments', desc: 'Threaded comments and moderation.', color: '152 76% 52%', icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
      { name: 'Tags', desc: 'Flexible tagging and categorization.', color: '172 66% 50%', icon: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>' },
    ];

    const grid = document.getElementById('cap-grid');
    capabilities.forEach((cap, i) => {
      const slug = cap.name.toLowerCase().replace(/\s/g, '-');
      const card = document.createElement('div');
      card.className = 'cap-card anim';
      card.style.animationDelay = `${i * 0.04}s`;
      card.innerHTML = `
        <div class="cap-hover-glow" style="background:radial-gradient(circle at 30% 20%, hsl(${cap.color} / 0.08), transparent 60%)"></div>
        <div class="cap-top-glow" style="background:linear-gradient(90deg, transparent, hsl(${cap.color} / 0.5), transparent)"></div>
        <div style="position:relative;z-index:1">
          <div class="cap-icon-box" style="background:hsl(${cap.color} / 0.1);border:1px solid hsl(${cap.color} / 0.15)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="hsl(${cap.color})" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${cap.icon}</svg>
          </div>
          <h3>${cap.name}</h3>
          <p class="cap-desc">${cap.desc}</p>
        </div>
        <div class="cap-hint">backcap add ${slug}</div>
      `;
      grid.appendChild(card);
    });

    // Re-observe newly added capability cards
    document.querySelectorAll('.cap-card.anim:not(.visible)').forEach(el => observer.observe(el));
  </script>

</body>
</html>
