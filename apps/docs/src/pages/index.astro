  /* ── AI Section ── */
  .landing .ai-section { position: relative; }
  .landing .ai-section .bg-grid { position: absolute; inset: 0; opacity: 0.15; }
  .landing .ai-grid {
    display: grid; gap: 1.5rem; max-width: 56rem; margin: 0 auto;
    position: relative; z-index: 1;
  }
  @media (min-width: 768px) { .landing .ai-grid { grid-template-columns: repeat(3, 1fr); } }
  .landing .ai-card {
    padding: 2rem; border-radius: 0.75rem; border: 1px solid var(--lp-border);
    background: var(--lp-card); transition: all 0.3s;
    text-decoration: none; color: inherit; display: block;
  }
  .landing .ai-card:hover {
    border-color: hsl(152 76% 52% / 0.3);
    box-shadow: 0 0 40px hsl(152 76% 52% / 0.08);
    transform: translateY(-2px);
  }
  .landing .ai-card svg {
    width: 2rem; height: 2rem; color: var(--lp-primary); margin-bottom: 1.25rem;
  }
  .landing .ai-card h3 { font-weight: 700; font-size: 1.125rem; margin-bottom: 0.75rem; }
  .landing .ai-card p { font-size: 0.875rem; color: var(--lp-muted); line-height: 1.7; }

  /* ── Frameworks ── */
  .landing .fw-section { position: relative; }
  .landing .fw-centered {
    max-width: 36rem; margin: 0 auto; text-align: center;
  }
  .landing .arch-label {
    font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;
    color: var(--lp-muted); text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .landing .fw-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1.5rem;
    justify-items: center;
  }
  .landing .fw-grid.runtimes { grid-template-columns: repeat(3, 1fr); }
  .landing .fw-grid-5 { grid-template-columns: repeat(5, 1fr); }
  @media (max-width: 500px) {
    .landing .fw-grid { grid-template-columns: repeat(3, 1fr); }
    .landing .fw-grid-5 { grid-template-columns: repeat(3, 1fr); }
  }
  .landing .fw-card {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.625rem; padding: 1rem 0.75rem; border-radius: 0.625rem;
    border: 1px solid var(--lp-border); background: var(--lp-card); transition: all 0.25s;
    width: 100%;
  }
  .landing .fw-card:hover {
    border-color: hsl(152 76% 52% / 0.35); background: hsl(220 18% 9%);
    transform: translateY(-2px);
  }
  .landing .fw-card-icon {
    width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center;
    color: var(--lp-muted); transition: color 0.25s;
  }
  .landing .fw-card:hover .fw-card-icon { color: var(--lp-primary); }
  .landing .fw-card-icon svg { width: 1.5rem; height: 1.5rem; }
  .landing .fw-card-name {
    font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; font-weight: 500;
  }

  /* ── CTA ── */
  .landing .cta-section { position: relative; padding: 8rem 0; }
  .landing .cta-orb {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 600px; height: 600px; border-radius: 50%;
    background: hsl(152 76% 52% / 0.05); filter: blur(150px);
  }
  .landing .cta-content { position: relative; z-index: 1; text-align: center; max-width: 42rem; margin: 0 auto; }
  .landing .cta-content h2 {
    font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin-bottom: 1.5rem;
  }
  .landing .cta-content .sub { color: var(--lp-muted); font-size: 1.125rem; margin-bottom: 2.5rem; }
  .landing .cta-btns {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 1rem; margin-bottom: 3rem;
  }
  .landing .cta-github { color: var(--lp-muted); font-size: 0.875rem; transition: color 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; }
  .landing .cta-github:hover { color: var(--lp-fg); }
  .landing .cta-footer {
    margin-top: 4rem; display: flex; align-items: center; justify-content: center;
    gap: 2rem; font-size: 0.875rem; color: var(--lp-muted);
    font-family: 'JetBrains Mono', monospace;
  }
  .landing .cta-dot { width: 0.25rem; height: 0.25rem; border-radius: 50%; background: var(--lp-primary); }
  .landing .cta-microcopy {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-top: 1.5rem; font-size: 0.8125rem; color: var(--lp-muted);
  }
  .landing .cta-microcopy svg {
    width: 0.875rem; height: 0.875rem; color: hsl(152 76% 52% / 0.6); flex-shrink: 0;
  }

  /* ── Glow Effects ── */
  .landing .section-with-glow { position: relative; overflow: hidden; }
  .landing .section-orb {
    position: absolute; width: 400px; height: 400px; border-radius: 50%;
    filter: blur(120px); pointer-events: none; z-index: 0;
  }
  .landing .section-orb.left { top: 20%; left: -10%; background: hsl(152 76% 52% / 0.04); }
  .landing .section-orb.right { bottom: 10%; right: -8%; background: hsl(172 66% 50% / 0.03); }
  .landing .section-with-glow .container { position: relative; z-index: 1; }
  .landing .glow-enhanced {
    position: relative; overflow: hidden;
    border-color: hsl(152 76% 52% / 0.25) !important;
    box-shadow: 0 0 40px hsl(152 76% 52% / 0.08);
  }
  .landing .glow-enhanced::before {
    content: ''; position: absolute; top: -80px; right: -80px;
    width: 200px; height: 200px; border-radius: 50%;
    background: hsl(152 76% 52% / 0.06); filter: blur(50px); pointer-events: none;
  }
  .landing .glow-enhanced::after {
    content: ''; position: absolute; bottom: -60px; left: -40px;
    width: 150px; height: 150px; border-radius: 50%;
    background: hsl(172 66% 50% / 0.04); filter: blur(40px); pointer-events: none;
  }

  .landing .icon { display: inline-block; vertical-align: middle; }
</style>

<script>
  // ── Scroll animations ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.landing .anim:not(.visible)').forEach(el => observer.observe(el));

  // ── Copy button handler ──
  document.querySelectorAll('.cmd-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.closest('.cmd-box')?.querySelector('span:not(.dollar)')?.textContent || '';
      navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });

  // ── Terminal animation ──
  const lines = [
    { html: '<span class="prompt-char">$ </span><strong>npx @backcap/cli init</strong>', cls: 'tl-cmd', delay: 800 },
    { html: '', cls: 'tl-empty', delay: 60 },
    { html: '┌  <strong>backcap init</strong>', cls: 'tl-clack-intro', delay: 300 },
    { html: '│', cls: 'tl-clack', delay: 100 },
    { html: '◆  Which framework are you using?', cls: 'tl-clack', delay: 400 },
    { html: '│  ○ Next.js', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│  ○ Express', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│  <span class="tl-success">●</span> <strong>Fastify</strong>', cls: 'tl-clack', delay: 600 },
    { html: '│  ○ NestJS', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│  ○ Hono', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│', cls: 'tl-clack', delay: 200 },
    { html: '◆  Which package manager are you using?', cls: 'tl-clack', delay: 400 },
    { html: '│  ○ npm', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│  <span class="tl-success">●</span> <strong>pnpm</strong>', cls: 'tl-clack', delay: 500 },
    { html: '│  ○ yarn', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│  ○ bun', cls: 'tl-clack tl-muted', delay: 80 },
    { html: '│', cls: 'tl-clack', delay: 200 },
    { html: '<span class="tl-tag">[backcap]</span> <span class="tl-success">✓</span> backcap.json created', cls: '', delay: 300 },
    { html: '<span class="tl-tag">[backcap]</span> <span class="tl-success">✓</span> tsconfig.json paths updated', cls: '', delay: 150 },
    { html: '', cls: 'tl-empty', delay: 60 },
    { html: '└  backcap.json created successfully!', cls: 'tl-outro', delay: 0 },
  ];

  const body = document.getElementById('terminal-body');
  let idx = 0;

  function addLine() {
    if (!body || idx >= lines.length) return;
    const line = lines[idx];
    const div = document.createElement('div');
    div.className = 'terminal-line show ' + line.cls;
    div.innerHTML = line.html;
    const cursor = body.querySelector('.terminal-cursor');
    if (cursor) cursor.remove();
    body.appendChild(div);
    idx++;
    if (idx < lines.length) {
      const c = document.createElement('span');
      c.className = 'terminal-cursor';
      body.appendChild(c);
      setTimeout(addLine, lines[idx].delay);
    }
  }

  const terminalEl = document.getElementById('terminal');
  if (terminalEl) {
    const terminalObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setTimeout(addLine, 500);
          terminalObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    terminalObs.observe(terminalEl);
  }
</script>
