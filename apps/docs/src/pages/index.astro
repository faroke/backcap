---
// Custom landing page — replaces Starlight default index
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Backcap — The shadcn/ui for backends</title>
  <meta name="description" content="A registry of composable backend capabilities for TypeScript. Install backend features like packages." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: hsl(220 20% 4%);
      --fg: hsl(210 20% 92%);
      --card: hsl(220 18% 7%);
      --primary: hsl(152 76% 52%);
      --primary-fg: hsl(220 20% 4%);
      --accent: hsl(172 66% 50%);
      --secondary: hsl(220 16% 12%);
      --muted: hsl(215 14% 50%);
      --border: hsl(220 14% 16%);
      --destructive: hsl(0 84% 60%);
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .font-mono { font-family: 'JetBrains Mono', monospace; }

    a { color: inherit; text-decoration: none; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ── Utilities ── */
    .text-gradient {
      background-image: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .glow-primary { box-shadow: 0 0 40px hsl(152 76% 52% / 0.15); }
    .border-glow { border-color: hsl(152 76% 52% / 0.3); }

    .bg-grid {
      background-image:
        linear-gradient(hsl(220 14% 16% / 0.5) 1px, transparent 1px),
        linear-gradient(90deg, hsl(220 14% 16% / 0.5) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    /* ── Animations ── */
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in-left {
      from { opacity: 0; transform: translateX(-24px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes fade-in-right {
      from { opacity: 0; transform: translateX(24px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes terminal-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .anim { opacity: 0; transform: translateY(24px); }
    .anim.visible { animation: fade-in-up 0.6s ease-out forwards; }
    .anim.from-left { transform: translateX(-24px); }
    .anim.from-left.visible { animation: fade-in-left 0.6s ease-out forwards; }
    .anim.from-right { transform: translateX(24px); }
    .anim.from-right.visible { animation: fade-in-right 0.6s ease-out forwards; }

    .d1 { animation-delay: 0.1s; }
    .d2 { animation-delay: 0.2s; }
    .d3 { animation-delay: 0.3s; }
    .d4 { animation-delay: 0.4s; }
    .d5 { animation-delay: 0.5s; }

    /* ── Navbar ── */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      border-bottom: 1px solid hsl(220 14% 16% / 0.5);
      background: hsl(220 20% 4% / 0.8);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
    }
    .navbar-inner {
      display: flex; align-items: center; justify-content: space-between;
      height: 4rem;
    }
    .navbar-left { display: flex; align-items: center; gap: 2rem; }
    .logo { display: flex; align-items: center; gap: 0.5rem; }
    .logo-icon {
      width: 1.5rem; height: 1.5rem; border-radius: 0.25rem;
      background: var(--primary); display: flex; align-items: center; justify-content: center;
      color: var(--primary-fg); font-weight: 700; font-size: 0.75rem;
    }
    .logo-text { font-weight: 700; font-size: 1.125rem; }
    .nav-links { display: flex; gap: 1.5rem; font-size: 0.875rem; color: var(--muted); }
    .nav-links a:hover { color: var(--fg); }
    .github-star {
      display: inline-flex; align-items: center; gap: 0.625rem;
      padding: 0.4rem 0.875rem; border-radius: 0.5rem;
      border: 1px solid var(--border); font-size: 0.8125rem; color: var(--muted);
      transition: all 0.2s; font-weight: 500;
    }
    .github-star:hover { color: var(--fg); border-color: hsl(152 76% 52% / 0.3); }
    .github-star svg { flex-shrink: 0; }
    .github-star-count {
      display: inline-flex; align-items: center; gap: 0.25rem;
      padding-left: 0.625rem; border-left: 1px solid var(--border);
      font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
      color: var(--fg); font-weight: 600;
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .github-label { display: none; }
    }

    /* ── Hero ── */
    .hero {
      position: relative; min-height: 100vh; display: flex; align-items: center;
      justify-content: center; overflow: hidden; padding-top: 4rem;
    }
    .hero .bg-grid { position: absolute; inset: 0; opacity: 0.3; }
    .hero-orb-1 {
      position: absolute; top: 33%; left: 25%;
      width: 500px; height: 500px; border-radius: 50%;
      background: hsl(152 76% 52% / 0.05); filter: blur(150px);
    }
    .hero-orb-2 {
      position: absolute; bottom: 25%; right: 25%;
      width: 400px; height: 400px; border-radius: 50%;
      background: hsl(172 66% 50% / 0.05); filter: blur(120px);
    }
    .hero-content { position: relative; z-index: 10; text-align: center; padding: 5rem 0; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.375rem 1rem; border-radius: 9999px;
      border: 1px solid hsl(152 76% 52% / 0.3); background: var(--secondary);
      font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; margin-bottom: 2rem;
    }
    .hero-badge-dot {
      width: 0.5rem; height: 0.5rem; border-radius: 50%;
      background: var(--primary); animation: terminal-blink 2s ease-in-out infinite;
    }
    .hero-badge span:last-child { color: var(--muted); }
    .hero h1 {
      font-size: clamp(2.5rem, 7vw, 5.5rem); font-weight: 800;
      letter-spacing: -0.03em; line-height: 0.95; margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.25rem); color: var(--muted);
      max-width: 40rem; margin: 0 auto 2.5rem; line-height: 1.7;
    }
    .hero-ctas {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
      gap: 1rem; margin-bottom: 3rem;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.5rem; border-radius: 0.5rem;
      background: var(--primary); color: var(--primary-fg);
      font-weight: 500; font-size: 0.875rem; transition: background 0.2s;
    }
    .btn-primary:hover { background: hsl(152 76% 45%); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.5rem; border-radius: 0.5rem;
      border: 1px solid var(--border); color: var(--muted);
      font-weight: 500; font-size: 0.875rem; transition: all 0.2s;
    }
    .btn-outline:hover { color: var(--fg); border-color: hsl(152 76% 52% / 0.3); }
    .cmd-box {
      display: inline-flex; align-items: center; gap: 0.75rem;
      padding: 0.75rem 1.25rem; border-radius: 0.5rem;
      background: var(--secondary); border: 1px solid var(--border);
      font-family: 'JetBrains Mono', monospace; font-size: 0.875rem;
      margin-bottom: 4rem;
    }
    .cmd-box .dollar { color: var(--muted); user-select: none; }
    .cmd-copy {
      background: none; border: none; color: var(--muted); cursor: pointer;
      padding: 0; margin-left: 0.5rem; transition: color 0.2s;
    }
    .cmd-copy:hover { color: var(--fg); }

    /* ── Terminal ── */
    .terminal {
      max-width: 42rem; margin: 0 auto; border-radius: 0.75rem;
      border: 1px solid var(--border); background: hsl(220 20% 3.5%); overflow: hidden;
      box-shadow: 0 0 60px hsl(152 76% 52% / 0.08), 0 25px 50px -12px rgba(0,0,0,0.5);
    }
    .terminal-bar {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1rem; border-bottom: 1px solid var(--border);
      background: hsl(220 18% 5.5%);
    }
    .terminal-dot { width: 0.75rem; height: 0.75rem; border-radius: 50%; }
    .terminal-dot.red { background: hsl(0 84% 50%); }
    .terminal-dot.yellow { background: hsl(45 96% 58%); }
    .terminal-dot.green { background: hsl(130 60% 46%); }
    .terminal-title {
      flex: 1; text-align: center; font-size: 0.75rem; color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .terminal-body {
      padding: 1.25rem 1.5rem; font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125rem; line-height: 1.6; min-height: 340px;
    }
    .terminal-line { opacity: 0; transition: opacity 0.15s; white-space: pre; }
    .terminal-line.show { opacity: 1; }
    .tl-cmd { color: hsl(210 20% 70%); }
    .tl-cmd .prompt-char { color: var(--muted); user-select: none; }
    .tl-cmd strong { color: var(--fg); font-weight: 600; }
    .tl-clack-intro { color: var(--primary); }
    .tl-clack-bar { color: hsl(220 14% 25%); }
    .tl-clack-select { color: var(--accent); }
    .tl-clack-select .label { color: hsl(210 20% 70%); }
    .tl-tag { color: hsl(152 76% 52% / 0.5); }
    .tl-info { color: hsl(200 80% 65%); }
    .tl-success { color: var(--primary); }
    .tl-file { color: var(--muted); }
    .tl-file .plus { color: var(--primary); }
    .tl-empty { height: 0.5rem; }
    .tl-outro { color: var(--primary); }
    .terminal-cursor {
      display: inline-block; width: 0.5rem; height: 1rem;
      background: var(--primary); animation: terminal-blink 1s step-end infinite;
      vertical-align: text-bottom;
    }

    /* ── Section shared ── */
    section { padding: 7rem 0; }
    .section-title {
      font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 700;
      margin-bottom: 1rem; text-align: center;
    }
    .section-sub {
      color: var(--muted); font-size: 1.125rem;
      max-width: 40rem; margin: 0 auto 4rem; text-align: center;
    }

    /* ── Problem ── */
    .problem-grid {
      display: grid; gap: 1.5rem; max-width: 56rem; margin: 0 auto;
    }
    @media (min-width: 768px) { .problem-grid { grid-template-columns: 1fr 1fr; } }
    .problem-card {
      padding: 1.5rem; border-radius: 0.75rem; background: var(--card);
    }
    .problem-card.bad { border: 1px solid hsl(0 84% 60% / 0.2); }
    .problem-card.good { border: 1px solid hsl(152 76% 52% / 0.2); }
    .problem-card h3 { font-weight: 600; font-size: 1.125rem; margin-bottom: 1.25rem; }
    .problem-item {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.875rem; padding: 0.375rem 0;
    }
    .problem-item.bad-item { color: var(--muted); }
    .problem-item.good-item code {
      font-family: 'JetBrains Mono', monospace; color: var(--primary);
    }
    .icon-x { color: var(--destructive); flex-shrink: 0; }
    .icon-check { color: var(--primary); flex-shrink: 0; }

    /* ── How it works ── */
    .how-section { position: relative; }
    .how-section .bg-grid { position: absolute; inset: 0; opacity: 0.15; }
    .how-grid {
      display: grid; gap: 2rem; max-width: 56rem; margin: 0 auto;
      position: relative; z-index: 1;
    }
    @media (min-width: 768px) { .how-grid { grid-template-columns: repeat(3, 1fr); } }
    .step-number {
      font-family: 'JetBrains Mono', monospace;
      font-size: 3rem; font-weight: 800; color: hsl(152 76% 52% / 0.1);
      margin-bottom: 1rem; display: block;
    }
    .step h3 { font-weight: 600; font-size: 1.125rem; margin-bottom: 0.75rem; }
    .step p { font-size: 0.875rem; color: var(--muted); margin-bottom: 1rem; }
    .step-code {
      border-radius: 0.5rem; background: var(--secondary);
      border: 1px solid var(--border); padding: 1rem;
      font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
      line-height: 1.8; color: var(--primary);
    }

    /* ── Examples ── */
    .examples-grid {
      display: grid; gap: 1.5rem; max-width: 64rem; margin: 0 auto;
    }
    @media (min-width: 768px) { .examples-grid { grid-template-columns: repeat(3, 1fr); } }
    .example-card {
      padding: 1.5rem; border-radius: 0.75rem;
      border: 1px solid var(--border); background: var(--card);
      transition: all 0.3s;
    }
    .example-card:hover { border-color: hsl(152 76% 52% / 0.3); box-shadow: 0 0 40px hsl(152 76% 52% / 0.15); }
    .example-icon {
      width: 2rem; height: 2rem; color: var(--primary); margin-bottom: 1rem;
      transition: transform 0.3s;
    }
    .example-card:hover .example-icon { transform: scale(1.1); }
    .example-card h3 { font-weight: 600; font-size: 1.25rem; margin-bottom: 1.25rem; }
    .example-list {
      border-radius: 0.5rem; background: var(--secondary);
      border: 1px solid var(--border); padding: 1rem;
      font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; line-height: 2;
    }
    .example-list span { color: var(--muted); }
    .example-list .plus { color: var(--primary); }

    /* ── Capabilities ── */
    .cap-section { position: relative; overflow: hidden; }
    .cap-section .bg-grid { position: absolute; inset: 0; opacity: 0.1; }
    .cap-ambient {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 800px; height: 600px; border-radius: 50%; opacity: 0.2;
      filter: blur(120px); pointer-events: none;
      background: radial-gradient(circle, hsl(152 76% 52% / 0.3), hsl(172 66% 50% / 0.1), transparent 70%);
    }
    .cap-badge {
      display: inline-block; font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--primary); margin-bottom: 1rem;
      padding: 0.25rem 0.75rem; border-radius: 9999px;
      border: 1px solid hsl(152 76% 52% / 0.2); background: hsl(152 76% 52% / 0.05);
    }
    .cap-grid {
      display: grid; gap: 0.75rem; max-width: 72rem; margin: 0 auto;
      position: relative; z-index: 1;
    }
    @media (min-width: 640px) { .cap-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .cap-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 1280px) { .cap-grid { grid-template-columns: repeat(4, 1fr); } }
    .cap-card {
      position: relative; padding: 1.25rem; border-radius: 0.75rem;
      border: 1px solid hsl(220 14% 16% / 0.6); background: hsl(220 18% 7% / 0.4);
      backdrop-filter: blur(4px); overflow: hidden;
      transition: all 0.5s; cursor: default;
    }
    .cap-card:hover { background: hsl(220 18% 7% / 0.8); transform: translateY(-2px); }
    .cap-hover-glow {
      position: absolute; inset: 0; opacity: 0;
      transition: opacity 0.5s; pointer-events: none;
    }
    .cap-card:hover .cap-hover-glow { opacity: 1; }
    .cap-top-glow {
      position: absolute; top: 0; left: 1rem; right: 1rem; height: 1px;
      opacity: 0; transition: opacity 0.5s;
    }
    .cap-card:hover .cap-top-glow { opacity: 1; }
    .cap-icon-box {
      width: 2rem; height: 2rem; border-radius: 0.5rem;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 0.75rem; transition: transform 0.3s;
    }
    .cap-card:hover .cap-icon-box { transform: scale(1.1); }
    .cap-icon-box svg { width: 1rem; height: 1rem; }
    .cap-card h3 { font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem; }
    .cap-card .cap-desc { font-size: 0.75rem; color: var(--muted); line-height: 1.5; }
    .cap-hint {
      position: absolute; bottom: 0.75rem; right: 0.75rem;
      font-family: 'JetBrains Mono', monospace; font-size: 0.625rem;
      color: hsl(152 76% 52% / 0.6); opacity: 0;
      transform: translateY(4px); transition: all 0.3s;
    }
    .cap-card:hover .cap-hint { opacity: 1; transform: translateY(0); }

    /* ── Architecture ── */
    .arch-grid {
      display: grid; gap: 4rem; max-width: 64rem; margin: 0 auto; align-items: center;
    }
    @media (min-width: 768px) { .arch-grid { grid-template-columns: 1fr 1fr; } }
    .arch-text h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 700; margin-bottom: 1.25rem; }
    .arch-text p { color: var(--muted); margin-bottom: 1.5rem; line-height: 1.7; }
    .arch-label {
      font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;
      color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;
    }
    .arch-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
    .arch-tag {
      padding: 0.375rem 0.75rem; border-radius: 0.375rem;
      background: var(--secondary); border: 1px solid var(--border);
      font-size: 0.875rem; font-family: 'JetBrains Mono', monospace;
    }
    .arch-tree {
      border-radius: 0.75rem; border: 1px solid var(--border);
      background: var(--card); padding: 1.5rem;
      font-family: 'JetBrains Mono', monospace; font-size: 0.875rem;
    }
    .arch-tree .dir { color: var(--primary); }
    .arch-tree .accent-dir { color: var(--accent); }
    .arch-tree .muted { color: var(--muted); }

    /* ── AI Section ── */
    .ai-section { position: relative; }
    .ai-section .bg-grid { position: absolute; inset: 0; opacity: 0.15; }
    .ai-grid {
      display: grid; gap: 1.5rem; max-width: 56rem; margin: 0 auto;
      position: relative; z-index: 1;
    }
    @media (min-width: 768px) { .ai-grid { grid-template-columns: repeat(3, 1fr); } }
    .ai-card {
      padding: 1.5rem; border-radius: 0.75rem;
      border: 1px solid var(--border); background: hsl(220 18% 7% / 0.5);
    }
    .ai-card svg { width: 1.5rem; height: 1.5rem; color: var(--primary); margin-bottom: 1rem; }
    .ai-card h3 { font-weight: 600; margin-bottom: 0.5rem; }
    .ai-card p { font-size: 0.875rem; color: var(--muted); line-height: 1.6; }

    /* ── CTA ── */
    .cta-section { position: relative; padding: 8rem 0; }
    .cta-orb {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 600px; height: 600px; border-radius: 50%;
      background: hsl(152 76% 52% / 0.05); filter: blur(150px);
    }
    .cta-content { position: relative; z-index: 1; text-align: center; max-width: 42rem; margin: 0 auto; }
    .cta-content h2 {
      font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin-bottom: 1.5rem;
    }
    .cta-content .sub { color: var(--muted); font-size: 1.125rem; margin-bottom: 2.5rem; }
    .cta-btns {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
      gap: 1rem; margin-bottom: 3rem;
    }
    .cta-github { color: var(--muted); font-size: 0.875rem; transition: color 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; }
    .cta-github:hover { color: var(--fg); }
    .cta-footer {
      margin-top: 4rem; display: flex; align-items: center; justify-content: center;
      gap: 2rem; font-size: 0.875rem; color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .cta-dot { width: 0.25rem; height: 0.25rem; border-radius: 50%; background: var(--primary); }

    /* SVG icons inline */
    .icon { display: inline-block; vertical-align: middle; }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="container navbar-inner">
      <div class="navbar-left">
        <a href="/" class="logo">
          <div class="logo-icon">B</div>
          <span class="logo-text">backcap</span>
        </a>
        <div class="nav-links">
          <a href="#capabilities">Capabilities</a>
          <a href="#architecture">Architecture</a>
          <a href={`${base}/getting-started/introduction`}>Docs</a>
        </div>
      </div>
      <a href="https://github.com/faroke/backcap" target="_blank" rel="noopener noreferrer" class="github-star">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        Star
        <span class="github-star-count" id="star-count">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span id="star-num">-</span>
        </span>
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="bg-grid"></div>
    <div class="hero-orb-1"></div>
