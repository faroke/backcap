    { name: 'Files', desc: 'Upload, storage & file management', color: '38 92% 55%', link: '/capabilities/files', icon: '<path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/>' },
    { name: 'Notifications', desc: 'In-app, email & push notifications', color: '280 70% 60%', link: '/capabilities/notifications', icon: '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>' },
    { name: 'Webhooks', desc: 'Outbound event delivery & retries', color: '152 76% 52%', link: '/capabilities/webhooks', icon: '<path d="M18 16.98h-5.99c-1.1 0-1.95.94-2.48 1.9A4 4 0 0 1 2 17c.01-.7.2-1.4.57-2"/><path d="m6 17 3.13-5.78c.53-.97.1-2.18-.5-3.1a4 4 0 1 1 6.89-4.06"/><path d="m12 6 3.13 5.73C15.66 12.7 16.9 13 18 13a4 4 0 0 1 0 8H12"/>' },
    { name: 'Queues', desc: 'Background jobs & task processing', color: '172 66% 50%', link: '/capabilities/queues', icon: '<rect width="7" height="18" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/>' },
    { name: 'RBAC', desc: 'Roles, permissions & access control', color: '45 96% 58%', link: '/capabilities/rbac', icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
    { name: 'Organizations', desc: 'Multi-tenant workspaces & teams', color: '260 60% 55%', link: '/capabilities/organizations', icon: '<path d="M18 21a8 8 0 0 0-16 0"/><circle cx="10" cy="8" r="5"/><path d="M22 20c0-3.37-2-6.5-4-8a5 5 0 0 0-.45-8.3"/>' },
    { name: 'Feature Flags', desc: 'Toggle features per user or env', color: '340 75% 55%', link: '/capabilities/feature-flags', icon: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/>' },
    { name: 'Audit Log', desc: 'Track every action in your system', color: '200 80% 55%', link: '/capabilities/audit-log', icon: '<rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>' },
    { name: 'Analytics', desc: 'Events, metrics & dashboards', color: '38 92% 55%', link: '/capabilities/analytics', icon: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
    { name: 'Forms', desc: 'Dynamic form schemas & submissions', color: '280 70% 60%', link: '/capabilities/forms', icon: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/>' },
    { name: 'Comments', desc: 'Threaded comments & moderation', color: '152 76% 52%', link: '/capabilities/comments', icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
    { name: 'Tags', desc: 'Flexible tagging & categorization', color: '172 66% 50%', link: '/capabilities/tags', icon: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>' },
    { name: 'Billing', desc: 'Payments, subscriptions & invoicing', color: '45 96% 58%', link: '/capabilities/billing', icon: '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>' },
  ];

  const arrow = '<svg class="cap-arrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';

  const grid = document.getElementById('cap-grid');
  if (grid) {
    capabilities.forEach((cap, i) => {
      const isAvailable = !!cap.link;
      const tag = isAvailable ? 'a' : 'div';
      const card = document.createElement(tag);
      card.className = 'cap-card anim' + (isAvailable ? '' : ' is-soon');
      if (isAvailable) card.href = base + cap.link;
      card.style.animationDelay = `${i * 0.04}s`;
      card.innerHTML = `
        <div class="cap-icon" style="background:hsl(${cap.color} / 0.1)">
          <svg viewBox="0 0 24 24" fill="none" stroke="hsl(${cap.color})" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${cap.icon}</svg>
        </div>
        <div class="cap-info">
          <h3>${cap.name}${isAvailable ? '' : '<span class="cap-soon-tag">soon</span>'}</h3>
          <p>${cap.desc}</p>
        </div>
        ${isAvailable ? arrow : ''}
      `;
      grid.appendChild(card);
    });

    document.querySelectorAll('.cap-card.anim:not(.visible)').forEach(el => observer.observe(el));
  }
</script>
