generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Blog Capability — Prisma Schema Fragment
model Post {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  authorId    String
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  publishedAt DateTime?
}
