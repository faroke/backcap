// ============================================================
// Auth Capability — Prisma Schema Fragment
// ============================================================
// INSTRUCTIONS:
// 1. Copy the model below into your main schema.prisma file
// 2. Run: npx prisma migrate dev --name auth
// 3. Run: npx prisma generate
// ============================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  roles        String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
